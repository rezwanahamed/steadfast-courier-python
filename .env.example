# SteadFast Courier API Configuration
# Copy this file to .env and fill in your credentials

# Required: Your SteadFast Courier API Key
STEADFAST_API_KEY=your-api-key

# Required: Your SteadFast Courier Secret Key
STEADFAST_SECRET_KEY=your-secret-key

# Optional: Custom base URL (defaults to official API)
STEADFAST_BASE_URL=https://portal.packzy.com/api/v1

# Optional: Request timeout in seconds (defaults to 30)
STEADFAST_TIMEOUT=30
